# -----------------------------------------------------------------------------
# ZOL — copy to .env.local and fill in values
#   cp .env.example .env.local
# -----------------------------------------------------------------------------

# --- Supabase (required for app + auth) -------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- OpenAI (required for agents) --------------------------------------------
OPENAI_API_KEY=

# --- Encryption (required for Google OAuth token storage) -------------------
# Generate: openssl rand -base64 32
ENCRYPTION_KEY=

# --- Vapi (voice: phone numbers, assistants, webhooks) ------------------------
VAPI_API_KEY=
VAPI_WEBHOOK_SECRET=
# Public URL Vapi POSTs to, e.g. https://your-domain.com/api/vapi/webhook
VAPI_WEBHOOK_URL=

# --- Google OAuth (Gmail + Calendar per shop) --------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Must match authorized redirect URIs in Google Cloud Console
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/api/google/oauth/callback

# --- GCP Cloud Tasks → Cloud Run worker --------------------------------------
GCP_PROJECT_ID=
GCP_REGION=us-central1
GCP_SERVICE_ACCOUNT_JSON=
CLOUD_TASKS_QUEUE_NAME=zol-agent-queue
WORKER_URL=

# --- App URLs ----------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Cloud Run worker only (optional locally; Cloud Run sets PORT) ------------
# PORT=8080
